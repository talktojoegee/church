{
  "name": "chms",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm run --parallel dev:api dev:web",
    "dev:api": "pnpm --filter chms-api dev",
    "dev:web": "pnpm --filter chms-web dev",
    "build": "pnpm run build:shared && pnpm --filter chms-api build && pnpm --filter chms-web build",
    "build:shared": "pnpm --filter @chms/shared build",
    "build:api": "pnpm --filter chms-api build",
    "build:web": "pnpm --filter chms-web build",
    "db:generate": "pnpm --filter chms-api db:generate",
    "db:migrate": "pnpm --filter chms-api db:migrate",
    "db:seed": "pnpm --filter chms-api db:seed",
    "test": "pnpm --filter chms-api test",
    "e2e": "bash scripts/e2e.sh",
    "lint": "pnpm run --parallel --filter chms-api --filter chms-web lint"
  }
}
