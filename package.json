{
  "name": "church-management-system",
  "version": "0.1.0",
  "private": true,
  "description": "Full-featured Church Management System (ChMS) built with NestJS + Next.js + MySQL",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:prod": "bash scripts/build-prod.sh",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "start": "turbo run start",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "mobile:pub": "cd apps/mobile && flutter pub get",
    "mobile:run": "cd apps/mobile && flutter run"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@chms/shared": "workspace:*",
    "@prisma/client": "^6.1.0",
    "argon2": "^0.41.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
