# Copy to docker/.env on the EC2 instance (not committed).
# docker compose -f docker/docker-compose.aws.yml --env-file docker/.env up -d --build

# --- AWS RDS MySQL (required) ---
# Format: mysql://USER:PASSWORD@RDS_ENDPOINT:3306/DATABASE
# Example: mysql://chms:SecretPass@chms.abc123.us-east-1.rds.amazonaws.com:3306/chms
DATABASE_URL=mysql://chms:CHANGE_ME@your-db.xxxxx.us-east-1.rds.amazonaws.com:3306/chms

# --- Domains (Caddy auto-SSL) ---
CADDY_EMAIL=admin@paggglobal.org
CORS_ORIGINS=https://paggglobal.org,https://www.paggglobal.org
COOKIE_DOMAIN=.paggglobal.org

# --- Frontend (baked into web image at build time) ---
NEXT_PUBLIC_API_URL=https://api.paggglobal.org/api
NEXT_PUBLIC_APP_NAME=Power And Glory Generation

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# --- Super admin (first seed) ---
SUPER_ADMIN_EMAIL=admin@paggglobal.org
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_NAME=Super Admin

# --- Church ---
DEFAULT_CHURCH_NAME=Power And Glory Generation

# --- Email (AWS SES or any SMTP) ---
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Power And Glory Generation <no-reply@paggglobal.org>

# --- Paystack ---
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
