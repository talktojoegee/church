# ----------------------------------------------------------------------------
# Church Management System - Environment Variables (copy to .env)
# ----------------------------------------------------------------------------

# --- Database (MySQL) ---
# Local dev (docker-compose) default:
DATABASE_URL="mysql://chms:chms_password@localhost:3306/chms"

# --- API server ---
API_PORT=4000
API_PREFIX=api
NODE_ENV=development

# CORS: comma-separated list of allowed origins (the web app URL)
CORS_ORIGINS="http://localhost:3000"

# --- Auth / JWT ---
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"
# Cookie domain for refresh token (leave blank for localhost)
COOKIE_DOMAIN=""

# --- Super admin (seeded on first run) ---
SUPER_ADMIN_EMAIL="admin@church.local"
SUPER_ADMIN_PASSWORD="ChangeMe123!"
SUPER_ADMIN_NAME="Super Admin"

# --- Organization defaults ---
DEFAULT_CHURCH_NAME="My Church"
DEFAULT_CURRENCY="NGN"
DEFAULT_LOCALE="en-NG"
DEFAULT_TIMEZONE="Africa/Lagos"

# --- Email (SMTP - Hostinger mail or any provider) ---
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASSWORD=""
MAIL_FROM="My Church <no-reply@church.local>"

# --- SMS (Termii — Nigeria) ---
# Set SMS_PROVIDER=termii and add your API key from https://termii.com
SMS_PROVIDER=""
SMS_API_KEY=""
SMS_SENDER_ID="CHURCH"

# --- Bulk SMS (KudiSMS / wallet) ---
SMS_DEFAULT_GATEWAY=kudisms
KUDI_SMS_API_KEY=""
KUDI_BASE_URL="https://my.kudisms.net/api/sms"
RETAIL_SMS_COST=5.95

# --- Paystack (SMS wallet top-up) ---
PAYSTACK_PUBLIC_KEY=""
PAYSTACK_SECRET_KEY=""
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""

# --- File uploads ---
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB=50

# --- Push notifications (FCM) — optional ---
# Path to Firebase service account JSON, OR inline JSON string.
# Leave both blank to use in-app notifications only.
FCM_SERVICE_ACCOUNT_PATH=""
# FCM_SERVICE_ACCOUNT_JSON=""

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_APP_NAME="Church Management System"
