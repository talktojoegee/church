# Copy to deploy.env and fill in SSH details (deploy.env is gitignored).

# --- Hostinger Business (two Node.js apps) — see hostinger/DEPLOYMENT.md ---
DEPLOY_HOST=YOUR_SSH_IP_OR_HOSTNAME
DEPLOY_USER=u421975600
DEPLOY_SSH_PORT=65002
DEPLOY_SSH_KEY=~/.ssh/hostinger_paggglobal
DEPLOY_API_REMOTE_DIR=domains/api.paggglobal.org
DEPLOY_WEB_REMOTE_DIR=domains/paggglobal.org
# Optional: full path to node if auto-detect fails (find via: ls /opt/alt/alt-nodejs20/root/usr/bin/node)
# DEPLOY_NODE_BIN=/opt/alt/alt-nodejs20/root/usr/bin/node

# --- AWS EC2 (alternative) ---
# DEPLOY_HOST=YOUR_ELASTIC_IP
# DEPLOY_USER=ubuntu
# DEPLOY_PATH=/opt/chms
# DEPLOY_SSH_KEY=~/.ssh/your-key.pem

# --- Hostinger VPS + Docker (alternative) ---
# DEPLOY_HOST=your-vps-ip
# DEPLOY_USER=root
# DEPLOY_PATH=/opt/chms

# Baked into Next.js at build time
NEXT_PUBLIC_API_URL=https://api.paggglobal.org/api
NEXT_PUBLIC_APP_NAME="Power And Glory Generation"
